# ============================================================
#  TalentScope Backend — Environment Variables
#  Copy this file to ".env" and fill in real values.
#  NEVER commit the real .env file to version control.
# ============================================================

# ---- Server ----
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS).
# Example for local dev + Vercel production:
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://talentscope.vercel.app
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ---- MySQL Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
DB_NAME=talentscope
# Set to true when connecting to a managed MySQL that requires SSL (PlanetScale, Railway, etc.)
DB_SSL=false

# ---- Authentication (JWT) ----
# Generate a strong secret, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=d79a76ffda3b83439524d835a1017d0b837c2353aea7ba69d6db19ead0b80897b35b4635c53cd2dd020b0b28106b15c1
JWT_EXPIRES_IN=1d
JWT_REMEMBER_EXPIRES_IN=7d

# ---- Password hashing ----
BCRYPT_SALT_ROUNDS=12

# ---- Default admin (created by the seed/migrate script) ----
ADMIN_NAME=Site Admin
ADMIN_EMAIL=admin@talentscope.com
ADMIN_PASSWORD=Admin@12345
