{
  "name": "talentscope-backend",
  "version": "1.0.0",
  "description": "REST API backend for TalentScope — Smart Job Eligibility & Salary Estimator (Node.js + Express + MySQL + JWT).",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/migrate.js --seed"
  },
  "keywords": [
    "express",
    "mysql",
    "jwt",
    "rest-api",
    "bcrypt",
    "talentscope"
  ],
  "author": "JavaScript Power Challenge",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.0"
  }
}
